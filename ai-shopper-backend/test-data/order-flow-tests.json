{
  "info": {
    "name": "AI Shopper - Order Flow Tests",
    "description": "Complete order flow testing: Add to Cart → Checkout → Verify Cart Cleared → List Orders → Get Order Detail",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "pm.collectionVariables.set('accessToken', jsonData.accessToken);",
              "pm.collectionVariables.set('refreshToken', jsonData.refreshToken);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": "http://localhost:5000/auth/login",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test1@example.com\",\n  \"password\": \"password123\"\n}"
        }
      }
    },
    {
      "name": "2. Add Item to Cart",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.items && jsonData.items.length > 0) {",
              "  pm.collectionVariables.set('cartItemId', jsonData.items[0]._id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": "http://localhost:5000/cart/items",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productId\": \"10\",\n  \"title\": \"Laptop\",\n  \"price\": 1200,\n  \"thumbnail\": \"image.jpg\",\n  \"quantity\": 2\n}"
        }
      }
    },
    {
      "name": "3. Test 1 — Create Order (Checkout)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "pm.collectionVariables.set('orderId', jsonData.order._id);",
              "",
              "pm.test('Order created successfully', function() {",
              "  pm.expect(jsonData.message).to.eql('Order created successfully');",
              "  pm.expect(jsonData.order.totalAmount).to.eql(2400);",
              "  pm.expect(jsonData.order.status).to.eql('pending');",
              "  pm.expect(jsonData.order.items.length).to.eql(1);",
              "  pm.expect(jsonData.order.items[0].title).to.eql('Laptop');",
              "  pm.expect(jsonData.order.items[0].price).to.eql(1200);",
              "  pm.expect(jsonData.order.items[0].quantity).to.eql(2);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": "http://localhost:5000/orders",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": ""
        }
      }
    },
    {
      "name": "4. Test 2 — Check Cart (Should be Empty)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "",
              "pm.test('Cart should be empty after checkout', function() {",
              "  pm.expect(jsonData.items).to.be.an('array');",
              "  pm.expect(jsonData.items.length).to.eql(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "http://localhost:5000/cart",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ]
      }
    },
    {
      "name": "5. Test 3 — Get All Orders",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "",
              "pm.test('Orders list returned', function() {",
              "  pm.expect(jsonData.orders).to.be.an('array');",
              "  pm.expect(jsonData.orders.length).to.be.at.least(1);",
              "  pm.expect(jsonData.orders[0].totalAmount).to.eql(2400);",
              "  pm.expect(jsonData.orders[0].status).to.eql('pending');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "http://localhost:5000/orders",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ]
      }
    },
    {
      "name": "6. Test 4 — Get Single Order",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "",
              "pm.test('Single order returned', function() {",
              "  pm.expect(jsonData.order).to.not.be.empty;",
              "  pm.expect(jsonData.order.totalAmount).to.eql(2400);",
              "  pm.expect(jsonData.order.status).to.eql('pending');",
              "  pm.expect(jsonData.order.items).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "http://localhost:5000/orders/{{orderId}}",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "cartItemId",
      "value": ""
    },
    {
      "key": "orderId",
      "value": ""
    }
  ]
}