# ============================================
# Root .gitignore — covers entire monorepo
# ============================================

# --- Dependencies ---
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Next.js (Frontend) ---
.next/
out/

# --- Build outputs ---
build/
dist/

# --- Testing ---
coverage/

# --- Environment variables ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Debug logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- TypeScript ---
*.tsbuildinfo
next-env.d.ts

# --- Vercel ---
.vercel

# --- macOS ---
.DS_Store
*.pem
